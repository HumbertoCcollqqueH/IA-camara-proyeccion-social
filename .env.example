# ===========================================================================
#  CONFIGURACIÓN DEL SISTEMA  —  copia este archivo a  ".env"  y edítalo.
#  NUNCA subas tu .env real a internet: contiene claves y números privados.
#
#  IMPORTANTE: cada variable va en su propia línea, SIN comentarios al lado
#  del valor. Los comentarios (líneas que empiezan con #) van aparte.
# ===========================================================================

# ---------------------------------------------------------------------------
# 1) EVOLUTION API  (gateway de WhatsApp que corre en Docker)
# ---------------------------------------------------------------------------
# URL del contenedor de Evolution API.
#   - worker en tu Windows (host):   http://localhost:8080
#   - worker DENTRO de docker:       http://evolution-api:8080
EVOLUTION_API_URL=http://localhost:8080

# Nombre de la "instancia" de WhatsApp que crearás en el panel (puerto 8080/manager).
EVOLUTION_INSTANCE=vigilancia

# Clave global de la API. NO se descarga: TÚ la inventas. Debe ser IGUAL aquí
# y en docker-compose (que la lee de esta misma variable). Genera una con:
#   .venv\Scripts\python.exe -c "import secrets; print(secrets.token_hex(24))"
EVOLUTION_API_KEY=cambia-esta-clave-larga-y-aleatoria

# ---------------------------------------------------------------------------
# 2) NÚMEROS A NOTIFICAR  (hasta 4, separados por coma)
# ---------------------------------------------------------------------------
# Formato: código de país + número, SOLO dígitos (sin +, sin espacios).
# Formato Perú: 51XXXXXXXXX (reemplaza las X por tu número). Puedes dejarlo
# vacío y agregar los números después desde el dashboard.
RECIPIENTS=

# ---------------------------------------------------------------------------
# 3) BASE DE DATOS  (historial + configuración)
# ---------------------------------------------------------------------------
# PostgreSQL (recomendado, viene en el docker-compose):
DATABASE_URL=postgresql+psycopg2://vigilancia:vigilancia@localhost:5432/vigilancia
# Alternativa rápida sin Docker (solo para probar): borra la línea de arriba y
# descomenta esta:
# DATABASE_URL=sqlite:///vigilancia.db

# ---------------------------------------------------------------------------
# 4) HORARIO DE TOQUE DE QUEDA  (formato 24h "HH:MM", puede cruzar medianoche)
# ---------------------------------------------------------------------------
CURFEW_START=22:00
CURFEW_END=04:00

# ---------------------------------------------------------------------------
# 5) DETECCIÓN YOLO
# ---------------------------------------------------------------------------
# Modelo: yolo11n.pt (rápido) | yolo11s.pt (balance) | yolo11m.pt (preciso)
MODEL=yolo11s.pt

# Umbral de confianza para NOTIFICAR (tu requisito: 0.90 = 90%).
CONF_THRESHOLD=0.90

# Resolución de inferencia.
IMGSZ=640

# Dispositivo: vacío = automático.  cpu = forzar CPU.  0 = GPU NVIDIA.
# DÉJALO VACÍO si no sabes (no pongas texto aquí).
DEVICE=

# Frames seguidos con persona (>= umbral) antes de alertar.
CONFIRM_FRAMES=4

# Segundos mínimos entre alertas.
COOLDOWN_SECONDS=120

# Mejora nocturna (aclara pasillos oscuros). true | false
NIGHT_ENHANCE=true

# Adjuntar recorte del cuerpo de la persona. true | false
SEND_CROP=true

# ---------------------------------------------------------------------------
# 6) FUENTE DE VIDEO
# ---------------------------------------------------------------------------
# 0 = webcam. O una URL RTSP. O usa los campos de cámara IP de abajo.
VIDEO_SOURCE=0

# Cámara IP (si pones CAM_IP se arma el RTSP automáticamente). Déjalo vacío
# para usar la webcam.
CAM_IP=
CAM_USER=admin
CAM_PASSWORD=
# Perfil: hikvision | dahua | generic
CAM_PROFILE=hikvision
CAM_CHANNEL=101
CAM_RTSP_PORT=554

# ---------------------------------------------------------------------------
# 7) POSTGRES (lo usan el docker-compose y Evolution API)
# ---------------------------------------------------------------------------
POSTGRES_USER=vigilancia
POSTGRES_PASSWORD=vigilancia
POSTGRES_DB=vigilancia
